<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox prefHeight="600.0" prefWidth="780.0" spacing="20.0"
      style="-fx-background-color: #1a2540;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vis.controller.CustomerServiceController">

    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <FontIcon iconLiteral="fas-tools" iconSize="20" iconColor="WHITE"/>
        <Label text="My Service Records" textFill="WHITE">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
    </HBox>

    <TableView fx:id="serviceTable"
               style="-fx-background-color: #12192b; -fx-control-inner-background: #12192b; -fx-selection-bar: #2a3a5a;"
               VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colServiceID" prefWidth="90.0" text="Service ID"/>
            <TableColumn fx:id="colVehicleID" prefWidth="100.0" text="Vehicle ID"/>
            <TableColumn fx:id="colServiceDate" prefWidth="130.0" text="Date"/>
            <TableColumn fx:id="colServiceType" prefWidth="150.0" text="Service Type"/>
            <TableColumn fx:id="colDescription" prefWidth="200.0" text="Description"/>
            <TableColumn fx:id="colCost" prefWidth="100.0" text="Cost"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <VBox alignment="CENTER" spacing="10">
                <FontIcon iconLiteral="fas-tools" iconSize="36" iconColor="#2a3a5a"/>
                <Label text="No service records found" textFill="#5a6a8a" style="-fx-font-size: 13;"/>
            </VBox>
        </placeholder>
    </TableView>
</VBox>