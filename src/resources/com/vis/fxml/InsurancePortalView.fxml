<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #1a2540;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vis.controller.InsurancePortalController">

    <top>
        <VBox>
            <MenuBar style="-fx-background-color: #0d1321;">
                <Menu text="File">
                    <MenuItem text="Logout" onAction="#handleLogout"/>
                </Menu>
                <Menu text="View">
                    <MenuItem text="All Policies" onAction="#handleViewAllPolicies"/>
                    <MenuItem text="Add Policy" onAction="#handleAddPolicy"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#handleLogout"/>
                </Menu>
            </MenuBar>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="14"
                  style="-fx-background-color: #12192b; -fx-border-color: #2a3a5a; -fx-border-width: 0 0 1 0; -fx-padding: 0 24 0 24;">
            <FontIcon iconLiteral="fas-file-contract" iconSize="28" iconColor="#3498db"/>
            <VBox spacing="2">
                <Label fx:id="lblAgentName" text="Insurance Agent" textFill="WHITE"
                       style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                <Label text="Insurance Portal" textFill="#5a6a8a" style="-fx-font-size: 12;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label style="-fx-background-color: #1e3a5f; -fx-padding: 4 12; -fx-background-radius: 20; -fx-text-fill: #3498db; -fx-font-size: 11; -fx-font-weight: bold;"
                   text="INSURANCE AGENT"/>
            <Button onAction="#handleLogout" prefHeight="34"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 6;">
                <graphic>
                    <HBox alignment="CENTER" spacing="6">
                        <FontIcon iconLiteral="fas-sign-out-alt" iconSize="13" iconColor="WHITE"/>
                        <Label text="Logout" textFill="WHITE" style="-fx-font-size: 12;"/>
                    </HBox>
                </graphic>
            </Button>
        </HBox>
    </VBox>
    </top>

    <left>
        <VBox prefWidth="210.0" spacing="4"
              style="-fx-background-color: #12192b; -fx-border-color: #2a3a5a; -fx-border-width: 0 1 0 0; -fx-padding: 16 8;">

            <Label text="MANAGEMENT" textFill="#5a6a8a"
                   style="-fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 8 10 4 10;"/>

            <Button fx:id="navAllPolicies" maxWidth="1.7976931348623157E308" onAction="#handleViewAllPolicies"
                    style="-fx-background-color: #1e3a5f; -fx-text-fill: #3498db; -fx-alignment: CENTER_LEFT; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 10;">
                        <FontIcon iconLiteral="fas-list" iconSize="15" iconColor="#3498db"/>
                        <Label text="All Policies" textFill="#3498db" style="-fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="navAddPolicy" maxWidth="1.7976931348623157E308" onAction="#handleAddPolicy"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 10;">
                        <FontIcon iconLiteral="fas-plus-circle" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Add Policy" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #1a2540;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <!-- Content will be loaded here -->
        </StackPane>
    </center>

</BorderPane>
