<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="950.0" spacing="25.0" style="-fx-background-color: #1a2540;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vis.controller.InsuranceAddController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <VBox alignment="CENTER" spacing="8">
            <VBox alignment="CENTER" maxWidth="60" maxHeight="60" minWidth="60" minHeight="60"
                  style="-fx-background-color: #1e3a5f; -fx-background-radius: 15; -fx-border-color: #2a5080; -fx-border-radius: 15; -fx-border-width: 1;">
                <FontIcon iconLiteral="fas-plus-circle" iconSize="28" iconColor="#3498db"/>
            </VBox>
            <Label text="Register Insurance Policy" textFill="WHITE">
                <font><Font name="System Bold" size="24.0"/></font>
            </Label>
            <Label text="Enter vehicle and provider details to issue a new policy" textFill="#5a6a8a">
                <font><Font size="13.0"/></font>
            </Label>
        </VBox>

        <VBox maxWidth="600.0" spacing="20.0" style="-fx-background-color: #12192b; -fx-padding: 30; -fx-background-radius: 12; -fx-border-color: #2a3a5a; -fx-border-radius: 12;">
            <children>
                <GridPane hgap="25.0" vgap="18.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="160.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="350.0" />
                    </columnConstraints>
                    <children>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Select Vehicle" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                            <Label text="Search by registration or model" textFill="#5a6a8a" style="-fx-font-size: 10;" />
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #0a1628; -fx-padding: 0 12; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <FontIcon iconLiteral="fas-car" iconSize="14" iconColor="#5a6a8a"/>
                            <ComboBox fx:id="cbVehicles" promptText="Choose a vehicle..." HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                       style="-fx-background-color: transparent; -fx-text-fill: white;" />
                        </HBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Insurance Provider" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                            <Label text="Company name" textFill="#5a6a8a" style="-fx-font-size: 10;" />
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #0a1628; -fx-padding: 0 12; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <FontIcon iconLiteral="fas-industry" iconSize="14" iconColor="#5a6a8a"/>
                            <TextField fx:id="txtProvider" promptText="e.g. State Farm" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 0;" />
                        </HBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Policy Number" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                            <Label text="Reference number" textFill="#5a6a8a" style="-fx-font-size: 10;" />
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #0a1628; -fx-padding: 0 12; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <FontIcon iconLiteral="fas-file-contract" iconSize="14" iconColor="#5a6a8a"/>
                            <TextField fx:id="txtPolicyNumber" promptText="e.g. 88992211" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 10 0;" />
                        </HBox>

                        <Label text="Start Date" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <DatePicker fx:id="dpStartDate" prefWidth="350.0" 
                                    style="-fx-background-color: #0a1628; -fx-text-fill: white; -fx-border-color: #2a3a5a; -fx-border-radius: 6;" 
                                    GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="End Date" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <DatePicker fx:id="dpEndDate" prefWidth="350.0" 
                                    style="-fx-background-color: #0a1628; -fx-text-fill: white; -fx-border-color: #2a3a5a; -fx-border-radius: 6;" 
                                    GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label text="Policy Status" textFill="#bdc3c7" style="-fx-font-weight: bold; -fx-font-size: 12;" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <ComboBox fx:id="cbStatus" prefWidth="350.0" 
                                  style="-fx-background-color: #0a1628; -fx-text-fill: white; -fx-border-color: #2a3a5a; -fx-border-radius: 6;" 
                                  GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleClear" prefHeight="42.0" prefWidth="140.0" 
                                style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" 
                                text="Clear" />
                        <Button mnemonicParsing="false" onAction="#handleSave" prefHeight="42.0" prefWidth="200.0" 
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(39,174,96,0.3), 10, 0, 0, 5);" 
                                text="Save Policy" />
                    </children>
                </HBox>
            </children>
        </VBox>
        
        <Label fx:id="lblStatus" textFill="#e74c3c" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
    </children>
</VBox>
