<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox prefHeight="600.0" prefWidth="780.0" spacing="20.0"
      style="-fx-background-color: #1a2540;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vis.controller.CustomerVehiclesController">

    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <FontIcon iconLiteral="fas-car" iconSize="20" iconColor="WHITE"/>
        <Label text="My Vehicles" textFill="WHITE">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" prefWidth="240.0"
                   promptText="Search..."
                   style="-fx-background-color: #2a3a5a; -fx-text-fill: white; -fx-prompt-text-fill: #bdc3c7; -fx-padding: 8 10;"/>
        <Button onAction="#handleAddVehicle" prefHeight="34.0"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;">
            <graphic>
                <HBox alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="fas-plus" iconSize="12" iconColor="WHITE"/>
                    <Label text="Register Vehicle" textFill="WHITE" style="-fx-font-weight: bold;"/>
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <TableView fx:id="vehiclesTable"
               style="-fx-background-color: #12192b; -fx-control-inner-background: #12192b; -fx-selection-bar: #2a3a5a;"
               VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colVehicleID" prefWidth="90.0" text="Vehicle ID"/>
            <TableColumn fx:id="colRegistrationNumber" prefWidth="160.0" text="Registration #"/>
            <TableColumn fx:id="colMake" prefWidth="120.0" text="Make"/>
            <TableColumn fx:id="colModel" prefWidth="120.0" text="Model"/>
            <TableColumn fx:id="colYear" prefWidth="80.0" text="Year"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <VBox alignment="CENTER" spacing="10">
                <FontIcon iconLiteral="fas-car" iconSize="36" iconColor="#2a3a5a"/>
                <Label text="No vehicles registered yet" textFill="#5a6a8a" style="-fx-font-size: 13;"/>
            </VBox>
        </placeholder>
    </TableView>
</VBox>