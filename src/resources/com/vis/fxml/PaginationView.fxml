<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    PaginationView.fxml
    Satisfies:
      • ScrollPane with ≥20 dummy elements arranged vertically
      • Pagination element to flip between pages
      • ProgressBar
      • ProgressIndicator
-->
<VBox prefHeight="620.0" prefWidth="900.0"
      spacing="0"
      style="-fx-background-color: #1a2540;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vis.controller.PaginationController">

    <padding><Insets bottom="24" left="28" right="28" top="24"/></padding>

    <!-- ── Page title ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 18 0;">
        <FontIcon iconLiteral="fas-list-alt" iconSize="22" iconColor="#3498db"/>
        <VBox spacing="2">
            <Label text="Browse Registry" textFill="WHITE">
                <font><Font name="System Bold" size="22.0"/></font>
            </Label>
            <Label text="Paginated view of all registered vehicles"
                   textFill="#5a6a8a" style="-fx-font-size: 12;"/>
        </VBox>
    </HBox>

    <!-- ── Main content row ───────────────────────────────────────────── -->
    <HBox spacing="22" VBox.vgrow="ALWAYS">

        <!-- LEFT: ScrollPane + Pagination -->
        <VBox spacing="14" HBox.hgrow="ALWAYS">

            <!-- Count label -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-car" iconSize="14" iconColor="#3498db"/>
                <Label fx:id="lblPageInfo" text="Showing entries 1 – 5 of 25"
                       textFill="#8a9ab5" style="-fx-font-size: 12;"/>
            </HBox>

            <!-- ScrollPane: 5 cards per page, updated by PaginationController -->
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;
                               -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="itemContainer" spacing="10" style="-fx-padding: 4 0;">
                    <!-- Cards are added programmatically by PaginationController.loadPage() -->
                </VBox>
            </ScrollPane>

            <!-- Pagination control: flips between pages -->
            <Pagination fx:id="pagination"
                        style="-fx-background-color: #12192b; -fx-background-radius: 8;
                               -fx-padding: 8;"/>

        </VBox>

        <!-- RIGHT: Progress section -->
        <VBox spacing="20" prefWidth="240"
              style="-fx-background-color: #12192b; -fx-background-radius: 10;
                     -fx-border-color: #2a3a5a; -fx-border-radius: 10;
                     -fx-border-width: 1; -fx-padding: 20 18;">

            <HBox alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-tasks" iconSize="16" iconColor="#3498db"/>
                <Label text="Browse Progress" textFill="WHITE"
                       style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            </HBox>

            <Separator style="-fx-background-color: #2a3a5a;"/>

            <!-- ProgressBar -->
            <VBox spacing="6">
                <Label text="PROGRESS BAR" textFill="#5a6a8a"
                       style="-fx-font-size: 10; -fx-font-weight: bold;"/>
                <ProgressBar fx:id="progressBar"
                             prefWidth="200" prefHeight="14"
                             progress="0.2"
                             style="-fx-accent: #3498db; -fx-background-color: #2a3a5a;
                                    -fx-background-radius: 8; -fx-control-inner-background: #2a3a5a;"/>
            </VBox>

            <!-- ProgressIndicator -->
            <VBox spacing="8" alignment="CENTER">
                <Label text="PROGRESS INDICATOR" textFill="#5a6a8a"
                       style="-fx-font-size: 10; -fx-font-weight: bold;"/>
                <ProgressIndicator fx:id="progressIndicator"
                                   prefWidth="100" prefHeight="100"
                                   progress="0.2"
                                   style="-fx-progress-color: #3498db;"/>
            </VBox>

            <Separator style="-fx-background-color: #2a3a5a;"/>

            <!-- Text label updated by controller -->
            <Label fx:id="lblProgress"
                   text="Page 1 of 5  •  20% browsed"
                   textFill="#8a9ab5"
                   wrapText="true"
                   style="-fx-font-size: 12;"/>

            <!-- Stats summary -->
            <VBox spacing="8" style="-fx-padding: 8 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-database" iconSize="12" iconColor="#27ae60"/>
                    <Label fx:id="lblTotalEntries" text="Loading..." textFill="#5a6a8a" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-file-alt" iconSize="12" iconColor="#f39c12"/>
                    <Label text="Entries per page: 5" textFill="#5a6a8a" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-book-open" iconSize="12" iconColor="#9b59b6"/>
                    <Label fx:id="lblTotalPages" text="Loading..." textFill="#5a6a8a" style="-fx-font-size: 11;"/>
                </HBox>
            </VBox>

        </VBox>

    </HBox>

</VBox>
