<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.vis.controller.LoginController"
           style="-fx-background-color: #0a1628;">

    <HBox alignment="CENTER" maxWidth="960.0" maxHeight="640.0"
          style="-fx-background-color: #1a2540; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 10);">
        <fx:define>
            <ToggleGroup fx:id="roleGroup"/>
        </fx:define>

        <!-- ═══════════════ LEFT BRANDING ═══════════════ -->
        <VBox alignment="CENTER" prefHeight="640.0" prefWidth="400.0" spacing="16"
              style="-fx-background-color: linear-gradient(to bottom, #0a1628, #152a4a);">
        <padding><Insets left="40" right="40"/></padding>

        <VBox alignment="CENTER" prefWidth="72" prefHeight="72"
              style="-fx-background-color: #1e3a5f; -fx-background-radius: 20;
                     -fx-border-color: #2a5080; -fx-border-radius: 20; -fx-border-width: 1.5;">
            <FontIcon iconLiteral="fas-shield-alt" iconSize="32" iconColor="#3498db"/>
        </VBox>
        <Text fill="WHITE" text="VIS"><font><Font name="System Bold" size="56.0"/></font></Text>
        <Text fill="#3498db" text="Vehicle Identification System"><font><Font size="15.0"/></font></Text>
        <Rectangle width="60" height="2" fill="#2a5080"/>

        <VBox spacing="14" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox alignment="CENTER" prefWidth="30" prefHeight="30"
                      style="-fx-background-color: #1e3a5f; -fx-background-radius: 50;">
                    <FontIcon iconLiteral="fas-car" iconSize="13" iconColor="#3498db"/>
                </VBox>
                <Text fill="#8ab4d4" text="Vehicle Registration &amp; Tracking"><font><Font size="13.0"/></font></Text>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox alignment="CENTER" prefWidth="30" prefHeight="30"
                      style="-fx-background-color: #1e3a5f; -fx-background-radius: 50;">
                    <FontIcon iconLiteral="fas-shield-alt" iconSize="13" iconColor="#3498db"/>
                </VBox>
                <Text fill="#8ab4d4" text="Police Report Management"><font><Font size="13.0"/></font></Text>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox alignment="CENTER" prefWidth="30" prefHeight="30"
                      style="-fx-background-color: #1e3a5f; -fx-background-radius: 50;">
                    <FontIcon iconLiteral="fas-gavel" iconSize="13" iconColor="#3498db"/>
                </VBox>
                <Text fill="#8ab4d4" text="Violations &amp; Fines"><font><Font size="13.0"/></font></Text>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox alignment="CENTER" prefWidth="30" prefHeight="30"
                      style="-fx-background-color: #1e3a5f; -fx-background-radius: 50;">
                    <FontIcon iconLiteral="fas-tools" iconSize="13" iconColor="#3498db"/>
                </VBox>
                <Text fill="#8ab4d4" text="Service Record Logging"><font><Font size="13.0"/></font></Text>
            </HBox>
        </VBox>
    </VBox>

    <!-- ═══════════════ RIGHT FORM ═══════════════ -->
    <VBox alignment="CENTER" prefHeight="640.0" prefWidth="560.0" spacing="0"
          style="-fx-background-color: #1a2540;">
        <padding><Insets left="60" right="60" top="36" bottom="36"/></padding>

        <Label fx:id="lblFormTitle" text="Welcome Back"
               textFill="WHITE" style="-fx-font-size: 26; -fx-font-weight: bold;"/>
        <Label fx:id="lblFormSubtitle" text="Sign in to continue"
               textFill="#5a6a8a" style="-fx-font-size: 12; -fx-padding: 3 0 16 0;"/>

        <!-- Error box -->
        <HBox fx:id="errorBox" alignment="CENTER_LEFT" spacing="8" maxWidth="400"
              style="-fx-background-color: #4a1a1a; -fx-background-radius: 6;
                     -fx-padding: 10 14; -fx-border-color: #e74c3c;
                     -fx-border-radius: 6; -fx-border-width: 1; -fx-margin: 0 0 10 0;"
              visible="false" managed="false">
            <FontIcon iconLiteral="fas-exclamation-circle" iconSize="14" iconColor="#e74c3c"/>
            <Label fx:id="lblError" text="" textFill="#e74c3c"
                   style="-fx-font-size: 12;" wrapText="true" maxWidth="340"/>
        </HBox>
        <VBox style="-fx-padding: 0 0 6 0;" visible="false" managed="false"/>

        <!-- ══ REGISTER-ONLY FIELDS (hidden in login mode) ══ -->
        <VBox fx:id="registerFields" spacing="9" visible="false" managed="false"
              style="-fx-padding: 0 0 9 0;">

            <!-- First name + Surname on same row -->
            <HBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #12192b; -fx-background-radius: 6;
                             -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                             -fx-border-width: 1; -fx-padding: 0 10 0 10;">
                    <FontIcon iconLiteral="fas-user" iconSize="12" iconColor="#5a6a8a"/>
                    <TextField fx:id="firstNameField" promptText="First Name"
                               style="-fx-background-color: transparent; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #5a6a8a; -fx-padding: 9 0 9 5;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #12192b; -fx-background-radius: 6;
                             -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                             -fx-border-width: 1; -fx-padding: 0 10 0 10;">
                    <FontIcon iconLiteral="fas-user" iconSize="12" iconColor="#5a6a8a"/>
                    <TextField fx:id="lastNameField" promptText="Surname"
                               style="-fx-background-color: transparent; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #5a6a8a; -fx-padding: 9 0 9 5;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </HBox>

            <!-- Email -->
            <HBox alignment="CENTER_LEFT" spacing="8" maxWidth="400"
                  style="-fx-background-color: #12192b; -fx-background-radius: 6;
                         -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                         -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                <FontIcon iconLiteral="fas-envelope" iconSize="12" iconColor="#5a6a8a"/>
                <TextField fx:id="emailField" promptText="Email address"
                           style="-fx-background-color: transparent; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #5a6a8a; -fx-padding: 9 0 9 5;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- USERNAME -->
        <HBox alignment="CENTER_LEFT" spacing="8" maxWidth="400"
              style="-fx-background-color: #12192b; -fx-background-radius: 6;
                     -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                     -fx-border-width: 1; -fx-padding: 0 12 0 12;">
            <FontIcon iconLiteral="fas-id-badge" iconSize="12" iconColor="#5a6a8a"/>
            <TextField fx:id="usernameField" promptText="Username"
                       style="-fx-background-color: transparent; -fx-text-fill: white;
                              -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 5;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>
        <VBox style="-fx-padding: 0 0 9 0;"/>

        <!-- PASSWORD -->
        <HBox alignment="CENTER_LEFT" spacing="8" maxWidth="400"
              style="-fx-background-color: #12192b; -fx-background-radius: 6;
                     -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                     -fx-border-width: 1; -fx-padding: 0 12 0 12;">
            <FontIcon iconLiteral="fas-lock" iconSize="12" iconColor="#5a6a8a"/>
            <PasswordField fx:id="passwordField" promptText="Password"
                           style="-fx-background-color: transparent; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 5;"
                           HBox.hgrow="ALWAYS"/>
        </HBox>
        <VBox style="-fx-padding: 0 0 9 0;"/>

        <!-- CONFIRM PASSWORD (register only) -->
        <HBox fx:id="confirmPasswordBox" alignment="CENTER_LEFT" spacing="8" maxWidth="400"
              style="-fx-background-color: #12192b; -fx-background-radius: 6;
                     -fx-border-color: #2a3a5a; -fx-border-radius: 6;
                     -fx-border-width: 1; -fx-padding: 0 12 0 12;"
              visible="false" managed="false">
            <FontIcon iconLiteral="fas-lock" iconSize="12" iconColor="#5a6a8a"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                           style="-fx-background-color: transparent; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 5;"
                           HBox.hgrow="ALWAYS"/>
        </HBox>
        <VBox fx:id="confirmPasswordSpacer" style="-fx-padding: 0 0 9 0;"
              visible="false" managed="false"/>

        <!-- ROLE SELECTION -->
        <Label text="Select Your Role" textFill="#8a9ab5"
               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 0 0 7 0;"/>
        <HBox spacing="5" maxWidth="400">
            <ToggleButton fx:id="btnRoleOfficer" text="Officer" toggleGroup="$roleGroup"
                          prefWidth="95" prefHeight="34"
                          style="-fx-background-color: #12192b; -fx-text-fill: #8a9ab5; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="12" iconColor="#8a9ab5"/></graphic>
            </ToggleButton>
            <ToggleButton fx:id="btnRoleCustomer" text="Customer" toggleGroup="$roleGroup"
                          prefWidth="95" prefHeight="34"
                          style="-fx-background-color: #12192b; -fx-text-fill: #8a9ab5; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-user" iconSize="12" iconColor="#8a9ab5"/></graphic>
            </ToggleButton>
            <ToggleButton fx:id="btnRoleMechanic" text="Mechanic" toggleGroup="$roleGroup"
                          prefWidth="95" prefHeight="34"
                          style="-fx-background-color: #12192b; -fx-text-fill: #8a9ab5; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-wrench" iconSize="12" iconColor="#8a9ab5"/></graphic>
            </ToggleButton>
            <ToggleButton fx:id="btnRoleInsurance" text="Insure" toggleGroup="$roleGroup"
                          prefWidth="95" prefHeight="34"
                          style="-fx-background-color: #12192b; -fx-text-fill: #8a9ab5; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-file-contract" iconSize="12" iconColor="#8a9ab5"/></graphic>
            </ToggleButton>
        </HBox>
        <VBox style="-fx-padding: 0 0 16 0;"/>

        <HBox fx:id="forgotBox" alignment="CENTER" style="-fx-padding: 4 0 0 0;">
            <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                       style="-fx-text-fill: #5a6a8a; -fx-underline: false; -fx-font-size: 11;"/>
        </HBox>

        <VBox style="-fx-padding: 0 0 16 0;"/>

        <Button fx:id="btnPrimaryAction" onAction="#handlePrimaryAction" prefHeight="44.0" prefWidth="400.0"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-font-size: 14;">
            <graphic>
                <HBox alignment="CENTER" spacing="10">
                    <FontIcon fx:id="btnIcon" iconLiteral="fas-sign-in-alt" iconSize="16" iconColor="WHITE"/>
                    <Label fx:id="btnLabel" text="Sign In" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                </HBox>
            </graphic>
        </Button>
        <VBox style="-fx-padding: 0 0 16 0;"/>

        <HBox alignment="CENTER" spacing="5">
            <Label fx:id="lblTogglePrompt" text="Don't have an account?" textFill="#5a6a8a" style="-fx-font-size: 12;"/>
            <Hyperlink fx:id="lnkToggleMode" onAction="#handleToggleMode" text="Create Account"
                       style="-fx-text-fill: #3498db; -fx-font-weight: bold; -fx-underline: false; -fx-font-size: 12;"/>
        </HBox>

    </VBox>
</HBox>
</StackPane>
