<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #1a2540;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vis.controller.DashboardController">

    <top>
        <VBox>
            <MenuBar style="-fx-background-color: #0d1321;">
                <Menu text="File">
                    <MenuItem text="Exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="View">
                    <MenuItem text="Dashboard" onAction="#handleDashboard"/>
                    <MenuItem text="Vehicles" onAction="#handleVehicles"/>
                    <MenuItem text="Customers" onAction="#handleCustomers"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Police Reports" onAction="#handlePoliceReports"/>
                    <MenuItem text="Violations" onAction="#handleViolations"/>
                    <MenuItem text="Service Records" onAction="#handleServiceRecords"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Browse Registry" onAction="#handlePagination"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About VIS" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <HBox alignment="CENTER_RIGHT" prefHeight="56.0" spacing="20.0"
                  style="-fx-background-color: #12192b; -fx-border-color: #2a3a5a; -fx-border-width: 0 0 1 0;">
                <Label fx:id="lblUsername" text="Welcome" textFill="WHITE">
                    <font><Font size="14.0"/></font>
                </Label>
                <Label fx:id="lblRole"
                       style="-fx-background-color: #1e3a5f; -fx-padding: 4 12; -fx-background-radius: 20; -fx-text-fill: #3498db; -fx-font-size: 11; -fx-font-weight: bold;"
                       text="ADMIN"/>
                <HBox.margin><Insets right="30.0"/></HBox.margin>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="4"
              style="-fx-background-color: #12192b; -fx-border-color: #2a3a5a; -fx-border-width: 0 1 0 0; -fx-padding: 16 8;">

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 10 20 10;">
                <FontIcon iconLiteral="fas-shield-alt" iconSize="22" iconColor="#3498db"/>
                <Label text="VIS SYSTEM" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0"/></font>
                </Label>
            </HBox>

            <Button fx:id="btnDashboard" maxWidth="1.7976931348623157E308" onAction="#handleDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-tachometer-alt" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Dashboard" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnVehicles" maxWidth="1.7976931348623157E308" onAction="#handleVehicles"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-car" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Vehicles" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnCustomers" maxWidth="1.7976931348623157E308" onAction="#handleCustomers"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-users" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Customers" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnPoliceReports" maxWidth="1.7976931348623157E308" onAction="#handlePoliceReports"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-file-alt" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Police Reports" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnServiceRecords" maxWidth="1.7976931348623157E308" onAction="#handleServiceRecords"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-tools" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Service Records" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnViolations" maxWidth="1.7976931348623157E308" onAction="#handleViolations"
                    style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-exclamation-circle" iconSize="15" iconColor="#bdc3c7"/>
                        <Label text="Violations" textFill="#bdc3c7"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnPagination" maxWidth="1.7976931348623157E308" onAction="#handlePagination"
                    style="-fx-background-color: #1e3a5f; -fx-text-fill: #3498db; -fx-alignment: CENTER_LEFT; -fx-padding: 8 14; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <FontIcon iconLiteral="fas-list-alt" iconSize="15" iconColor="#3498db"/>
                        <Label text="Browse Registry" textFill="#3498db"/>
                    </HBox>
                </graphic>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
                <graphic>
                    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 6 0;">
                        <FontIcon iconLiteral="fas-sign-out-alt" iconSize="14" iconColor="WHITE"/>
                        <Label text="Logout" textFill="WHITE" style="-fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
                <VBox.margin><Insets bottom="20.0" left="10.0" right="10.0"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" BorderPane.alignment="CENTER">
            <Label text="Select an option from the sidebar" textFill="#7f8c8d"/>
        </StackPane>
    </center>

</BorderPane>