<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox prefHeight="600.0" prefWidth="780.0" spacing="20.0"
      style="-fx-background-color: #1a2540;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vis.controller.CustomerViolationsController">

    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <FontIcon iconLiteral="fas-exclamation-circle" iconSize="20" iconColor="#e74c3c"/>
        <Label text="My Violations" textFill="WHITE">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblSummary" textFill="#bdc3c7" style="-fx-font-size: 12;"/>
    </HBox>

    <TableView fx:id="violationsTable"
               style="-fx-background-color: #12192b; -fx-control-inner-background: #12192b; -fx-selection-bar: #2a3a5a;"
               VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colViolationID" prefWidth="100.0" text="Violation ID"/>
            <TableColumn fx:id="colVehicleID" prefWidth="100.0" text="Vehicle ID"/>
            <TableColumn fx:id="colViolationDate" prefWidth="130.0" text="Date"/>
            <TableColumn fx:id="colViolationType" prefWidth="160.0" text="Type"/>
            <TableColumn fx:id="colFineAmount" prefWidth="100.0" text="Fine (M)"/>
            <TableColumn fx:id="colAmountPaid" prefWidth="100.0" text="Paid (M)"/>
            <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <VBox alignment="CENTER" spacing="10">
                <FontIcon iconLiteral="fas-check-circle" iconSize="36" iconColor="#27ae60"/>
                <Label text="No violations found" textFill="#5a6a8a" style="-fx-font-size: 13;"/>
            </VBox>
        </placeholder>
    </TableView>
</VBox>