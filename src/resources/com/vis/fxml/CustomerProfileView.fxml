<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox prefHeight="600.0" prefWidth="700.0"
      spacing="0"
      style="-fx-background-color: #1a2540;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vis.controller.CustomerProfileController">

    <padding><Insets bottom="30" left="30" right="30" top="30"/></padding>

    <!-- Title -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 24 0;">
        <FontIcon iconLiteral="fas-user-cog" iconSize="22" iconColor="#3498db"/>
        <Label text="My Profile" textFill="WHITE">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
    </HBox>

    <!-- Profile card -->
    <VBox spacing="18"
          style="-fx-background-color: #12192b; -fx-background-radius: 10;
                 -fx-border-color: #2a3a5a; -fx-border-radius: 10;
                 -fx-border-width: 1; -fx-padding: 28 30;">

        <HBox spacing="20">
            <!-- First name -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="First Name" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 12;"/>
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color: #12192b; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                    <FontIcon iconLiteral="fas-user" iconSize="12" iconColor="#5a6a8a"/>
                    <TextField fx:id="fieldFirstName" promptText="First name"
                               style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 6;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            <!-- Surname -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Surname" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 12;"/>
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color: #12192b; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                    <FontIcon iconLiteral="fas-user" iconSize="12" iconColor="#5a6a8a"/>
                    <TextField fx:id="fieldSurname" promptText="Surname"
                               style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 6;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Email -->
        <VBox spacing="6">
            <Label text="Email Address" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 12;"/>
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: #12192b; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                <FontIcon iconLiteral="fas-envelope" iconSize="12" iconColor="#5a6a8a"/>
                <TextField fx:id="fieldEmail" promptText="Email address"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 6;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Phone -->
        <VBox spacing="6">
            <Label text="Phone Number" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 12;"/>
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: #12192b; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                <FontIcon iconLiteral="fas-phone" iconSize="12" iconColor="#5a6a8a"/>
                <TextField fx:id="fieldPhone" promptText="Phone number"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 6;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Address -->
        <VBox spacing="6">
            <Label text="Address" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 12;"/>
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-background-color: #12192b; -fx-background-radius: 6; -fx-border-color: #2a3a5a; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0 12 0 12;">
                <FontIcon iconLiteral="fas-map-marker-alt" iconSize="12" iconColor="#5a6a8a"/>
                <TextField fx:id="fieldAddress" promptText="Street address"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5a6a8a; -fx-padding: 10 0 10 6;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <Separator style="-fx-background-color: #2a3a5a;"/>

        <Button text="Save Changes" onAction="#handleSaveProfile"
                prefHeight="40" prefWidth="180"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;"/>

    </VBox>
</VBox>
